{
  "version": 2,
  "builds": [
    { "src": "index.html",      "use": "@vercel/static" },
    { "src": "css/**",          "use": "@vercel/static" },
    { "src": "js/**",           "use": "@vercel/static" },
    { "src": "components/**",   "use": "@vercel/static" },
    { "src": "imgs/**",         "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/css/(.*)",        "dest": "/css/$1" },
    { "src": "/js/(.*)",         "dest": "/js/$1" },
    { "src": "/components/(.*)", "dest": "/components/$1" },
    { "src": "/imgs/(.*)",       "dest": "/imgs/$1" },
    { "src": "/(.*)",            "dest": "/index.html" }
  ]
}
